<?xml version="1.0" encoding="utf-8"?>
<!--
  SDK built-in default Language Selection screen layout.
  All view IDs used here match what OxylabBaseLanguageActivity looks for by default.
  Apps can replace this entirely by overriding getLayoutResId().
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/oxylab_default_bg"
    android:orientation="vertical">

    <!-- Header row: title + checkmark button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingTop="20dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minHeight="40dp"
            android:gravity="center_vertical"
            android:text="@string/oxylab_default_choose_language"
            android:textColor="@color/oxylab_default_text_primary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!-- Done / continue button (shown by SDK after 2 s delay) -->
        <FrameLayout
            android:id="@+id/oxylab_lang_btn_done"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/oxylab_default_btn_bg"
            android:visibility="invisible">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/oxylab_default_check_circle" />
        </FrameLayout>
    </LinearLayout>

    <!-- Language list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/oxylab_lang_recycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp" />

    <!-- Native ad container -->
    <FrameLayout
        android:id="@+id/oxylab_lang_ad_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="80dp" />

</LinearLayout>
