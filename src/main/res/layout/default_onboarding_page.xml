<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/oxylab_default_bg"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <ImageView
                android:id="@+id/oxylab_ob_page_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:src="@drawable/oxylab_default_demo_image" />

            <View
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_gravity="top"
                android:background="@drawable/oxylab_default_fade_top" />

            <View
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_gravity="bottom"
                android:background="@drawable/oxylab_default_fade_bottom" />
        </FrameLayout>

        <TextView
            android:id="@+id/oxylab_ob_page_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="15dp"
            android:includeFontPadding="false"
            android:text="@string/oxylab_default_onboarding_title_1"
            android:textColor="@color/oxylab_default_text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/oxylab_ob_page_desc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="5dp"
            android:textAlignment="center"
            android:includeFontPadding="false"
            android:text="@string/oxylab_default_onboarding_desc_1"
            android:textColor="@color/oxylab_default_text_primary"
            android:textSize="16sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="20dp"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/oxylab_ob_page_dots_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_weight="1"
                android:orientation="horizontal">

                <View
                    android:layout_width="24dp"
                    android:layout_height="8dp"
                    android:layout_margin="4dp"
                    android:background="@drawable/oxylab_default_dot_active" />

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_margin="4dp"
                    android:background="@drawable/oxylab_default_dot_inactive" />

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_margin="4dp"
                    android:background="@drawable/oxylab_default_dot_inactive" />

            </LinearLayout>

            <TextView
                android:id="@+id/oxylab_ob_page_btn_next"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:includeFontPadding="false"
                android:text="@string/oxylab_default_continue"
                android:textColor="@color/oxylab_default_accent"
                android:textSize="19sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/oxylab_ob_page_ad_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp"
            android:minHeight="200dp"
            android:orientation="vertical" />
    </LinearLayout>
</LinearLayout>
